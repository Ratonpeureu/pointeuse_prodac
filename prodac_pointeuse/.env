# ═════════════════════════════════════════════
# TERMINAL DATA FORMAT
# ═════════════════════════════════════════════
TERMINAL_FORMAT=csv                          # csv | json | binary
TERMINAL_DELIMITER=,
TERMINAL_ENCODING=utf-8
TERMINAL_TIMESTAMP_FORMAT=%Y-%m-%d %H:%M:%S

# Custom field mapping (JSON string)
# TERMINAL_FIELD_MAPPING={"id_pointeuse": 0, "timestamp": 1, "action": 2, ...}

# ═════════════════════════════════════════════
# PAUSE MANAGEMENT
# ═════════════════════════════════════════════
PAUSE_MODE=terminal                          # terminal | system | hybrid
PAUSE_DEFAULT_MIN=60
PAUSE_VARIABLE=true
PAUSE_WARN_OVER_MIN=15
PAUSE_WARN_UNDER_MIN=10

# ═════════════════════════════════════════════
# POINTAGE RULES
# ═════════════════════════════════════════════
POINTAGE_ARRIVEE_MODE=first_only              # first_only | last_only
POINTAGE_DEPART_MODE=last_only                # Toujours dernier
ALLOW_REBADGE=false
REBADGE_IGNORE_MIN=5
LOG_ALL_ATTEMPTS=true

# ═════════════════════════════════════════════
# NETWORK
# ═════════════════════════════════════════════
TERMINAL_HOST=0.0.0.0
TERMINAL_PORT=9999
CLIENT_TIMEOUT_SEC=300
MAX_CLIENTS=50

# ═════════════════════════════════════════════
# LOGS
# ═════════════════════════════════════════════
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=structured                        # structured | simple | json
LOG_OUTPUT=both                              # console | file | both
LOG_FILE=./logs/pointage.log
LOG_MEMORY_RECORDS=1000

# ═════════════════════════════════════════════
# ENTERPRISE
# ═════════════════════════════════════════════
ENTERPRISE_NAME=Mon Entreprise
TIMEZONE=Africa/Dakar